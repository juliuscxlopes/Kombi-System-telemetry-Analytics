{
  "version": "2.0.0",
  "sensor_target": "OIL_TEMP",
  "updated_at": "2026-06-17",
  "settings": {
    "temporal_window_ms": 60000,
    "evaluation_interval_ms": 1000
  },
  
  "--- GERENCIAMENTO DE RISCO ESTÁTICO (LIMITES FÍSICOS DOS SENSORES) ---": {},
  "thresholds": {
    "OIL_TEMP": {
      "unit": "°C",
      "description": "Temperatura do Óleo (Mineral Estrutural)",
      "ranges": {
        "FRIO":         { "max": 70.0,  "severity": "AVISO",       "description": "Motor em aquecimento. Evitar rotação alta." },
        "OPERACIONAL":  { "min": 80.0,  "max": 90.0, "severity": "OPERACIONAL", "description": "Janela ideal de viscosidade e pressão." },
        "ALERTA":       { "min": 95.0,  "severity": "ALERTA",      "description": "Óleo começando a perder propriedades estruturais." },
        "CRITICO":      { "min": 100.0, "severity": "CRITICO",     "description": "Limite máximo do lubrificante mineral. Risco de quebra." }
      }
    }
  },

  "--- REGRAS CLÍNICAS DIRETAS (AÇÕES IMEDIATAS POR ESTOURO DE BARREIRA) ---": {},
  "direct_rules": [
    {
      "id": "ERR_PRE_DETONATION",
      "grau": 5,
      "severity": "CRITICO",
      "description": "Pré-detonação ativa no bloco! Risco severo de quebra de canaleta por choque térmico/mecânico.",
      "conditions": [
        { "sensor": "KNOCK", "operator": ">", "value": 0 }
      ],
      "contention": {
        "solution": ["FAN_OIL", "FAN_CHT"],
        "plan": "EMERGENCY_COOLING",
        "base_value": "100%"
      }
    },
    {
      "id": "ERR_LOW_PRESSURE_HOT",
      "grau": 3,
      "severity": "ALERTA",
      "description": "Pressão de óleo baixa em regime de cruzeiro com motor quente (Afinamento extremo do mineral).",
      "conditions": [
        { "sensor": "OIL_TEMP", "operator": ">=", "value": 92.0 },
        { "sensor": "RPM", "operator": ">=", "value": 2500 },
        { "sensor": "OIL_PRESSURE", "operator": "<", "value": 1.0 }
      ],
      "contention": {
        "solution": ["FAN_OIL"],
        "plan": "OILTdecreasePlan",
        "base_value": "50%"
      }
    }
  ],

  "--- REGRAS CLÍNICAS PREDITIVAS (GERENCIAMENTO DE ETA E TENDÊNCIA DE ANTECIPAÇÃO) ---": {},
  "predictive_rules": [
    {
      "id": "ERR_OVERHEAT_STRUCTURAL_PREDICTIVE",
      "grau": 4,
      "severity": "CRITICO",
      "description": "Análise termo-cinética projeta Saturação Térmica simultânea (Óleo + Cabeçote).",
      "target_conditions": [
        { "sensor": "OIL_TEMP", "value": 100.0 },
        { "sensor": "CHT", "value": 150.0 }
      ],
      "eta_steps": {
        "PREDICTIVE_1": { "min_eta": 30, "max_eta": 60, "plan": "OILTdecreasePlan", "value": "50%" },
        "PREDICTIVE_2": { "min_eta": 0,  "max_eta": 29, "plan": "OILTdecreasePlan", "value": "100%" }
      }
    },
    {
      "id": "ERR_OIL_CRITICAL_PREDICTIVE",
      "grau": 3,
      "severity": "CRITICO",
      "description": "Rampa de subida projeta colapso por temperatura do óleo mineral em curto prazo.",
      "target_conditions": [
        { "sensor": "OIL_TEMP", "value": 100.0 }
      ],
      "eta_steps": {
        "PREDICTIVE_1": { "min_eta": 30, "max_eta": 60, "plan": "OILTdecreasePlan", "value": "25%" },
        "PREDICTIVE_2": { "min_eta": 0,  "max_eta": 29, "plan": "OILTdecreasePlan", "value": "75%" }
      }
    }
  ]
}